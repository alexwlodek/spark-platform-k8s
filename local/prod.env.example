#!/usr/bin/env bash

# Copy this file to local/prod.env.sh and fill in your real values locally.
# local/prod.env.sh is gitignored.

# Required GCP / GKE settings.
export GCP_PROJECT_ID="replace-with-gcp-project-id"
export GCP_REGION="europe-central2"
export GCP_ZONES='["europe-central2-a","europe-central2-b","europe-central2-c"]'
export GKE_CLUSTER_NAME="data-platform-prod"

# Required first-bootstrap secrets.
export ARGOCD_ADMIN_PASSWORD="password123"
# Alternative to the plain password above:
# export ARGOCD_ADMIN_BCRYPT_HASH='$2a$10$replace-with-bcrypt-hash'
export GRAFANA_ADMIN_USER="admin"
export GRAFANA_ADMIN_PASSWORD="password123"
export CLOUDFLARE_API_TOKEN="replace-with-cloudflare-api-token"

# Optional DNS automation for the 00-network stage.
export CLOUDFLARE_ZONE_ID="replace-with-cloudflare-zone-id"
export BASE_DOMAIN="alexwlodek.com"
export ENVIRONMENT_SUBDOMAIN="prod"
export PUBLIC_HOSTNAMES='["argocd","grafana","kibana"]'

# Optional GKE access restrictions.
export GKE_MASTER_AUTHORIZED_NETWORKS='[]'
# export GKE_MASTER_AUTHORIZED_NETWORKS='[{"cidr_block":"203.0.113.10/32","display_name":"office-egress"}]'

# Optional Terraform sizing / naming overrides.
export GKE_PLATFORM_MACHINE_TYPE="e2-standard-2"
export GKE_PLATFORM_TOTAL_MIN_NODES="3"
export GKE_PLATFORM_TOTAL_MAX_NODES="6"
export CLOUD_SQL_TIER="db-custom-1-3840"
export TF_RESOURCE_LABELS='{}'

# If you change the derived names below, keep them aligned with the committed prod values/manifests.
# export GCP_NETWORK_NAME="data-platform-prod-vpc"
# export GCP_SUBNETWORK_NAME="data-platform-prod-gke"
# export LAKE_BUCKET_NAME="data-platform-prod-lake"
# export CLOUD_SQL_INSTANCE_NAME="data-platform-prod-nessie"
# export NESSIE_SECRET_ID="spark-platform-prod-storage-nessie"
