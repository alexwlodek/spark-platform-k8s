aws_region   = "eu-central-1"
cluster_name = "data-platform-prod"

cluster_version = "1.34"
vpc_cidr        = "10.70.0.0/16"

# Restrict this to corporate VPN / office IP ranges.
cluster_endpoint_public_access_cidrs = [
  "203.0.113.10/32",
]

node_group_instance_types = ["m6i.xlarge"]
node_group_desired_size   = 3
node_group_min_size       = 3
node_group_max_size       = 6
node_group_disk_size      = 120

argocd_hostname               = "argocd.prod.example.com"
external_secrets_secret_prefix = "/spark-platform/prod/"

tags = {
  Owner      = "platform-team"
  CostCenter = "data-platform-prod"
}
