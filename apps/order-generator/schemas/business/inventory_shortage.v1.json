{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://example.local/schemas/business/inventory_shortage.v1.json",
  "title": "inventory_shortage v1",
  "type": "object",
  "required": [
    "event_type",
    "event_version",
    "schema_ref",
    "order_id",
    "customer_id",
    "session_id",
    "payment_id",
    "reservation_id",
    "payload"
  ],
  "properties": {
    "event_type": { "const": "inventory_shortage" },
    "event_version": { "const": 1 },
    "schema_ref": { "const": "schemas/business/inventory_shortage.v1.json" },
    "payload": {
      "type": "object",
      "required": [
        "warehouse_id",
        "requested_qty",
        "reserved_qty",
        "stock_after",
        "shortage_reason_code",
        "missing_items",
        "region"
      ],
      "properties": {
        "warehouse_id": { "type": "string" },
        "requested_qty": { "type": "integer", "minimum": 1 },
        "reserved_qty": { "type": "integer", "minimum": 0 },
        "stock_after": { "type": "integer", "minimum": 0 },
        "shortage_reason_code": { "type": "string" },
        "region": { "type": "string" },
        "missing_items": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "object",
            "required": ["sku", "requested_qty", "missing_qty"],
            "properties": {
              "sku": { "type": "string" },
              "requested_qty": { "type": "integer", "minimum": 1 },
              "missing_qty": { "type": "integer", "minimum": 1 }
            },
            "additionalProperties": false
          }
        }
      },
      "additionalProperties": false
    }
  },
  "additionalProperties": true
}
